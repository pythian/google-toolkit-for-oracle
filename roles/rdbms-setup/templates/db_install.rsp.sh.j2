#!/bin/bash

# Define source and destination for the response file
{% if oracle_ver == "11.2.0.4.0" or oracle_ver == "12.1.0.2.0" or oracle_ver == "12.2.0.1.0" %}
RSP_SRC="{{ swlib_unzip_path }}/database/response/db_install.rsp"
{% else %}
RSP_SRC="{{ oracle_home }}/install/response/db_install.rsp"
{% endif %}

RSP_DEST="{{ swlib_unzip_path }}/db_install.rsp"

[[ -r "$RSP_SRC" ]] || { echo "db_install.rsp.sh: cannot read $RSP_SRC"; exit 1; }
cp "$RSP_SRC" "$RSP_DEST"

# 1. Installation Options and Edition (Handling modern and legacy keys)
# Use [# ]* to match optional comment characters or spaces at the start of the line
sed -i 's~^[# ]*\(oracle.install.option\|installOption\)=.*$~\1=INSTALL_DB_SWONLY~' "$RSP_DEST"
sed -i 's~^[# ]*\(oracle.install.db.InstallEdition\|installEdition\)=.*$~\1={{ oracle_edition }}~' "$RSP_DEST"

# 2. Host and Core Paths
# Note: Using 'hostname' is safer than 'hostname -A' which can return multiple names/IPs
sed -i 's~^[# ]*ORACLE_HOSTNAME=.*$~ORACLE_HOSTNAME=`hostname`~' "$RSP_DEST"
sed -i 's~^[# ]*UNIX_GROUP_NAME=.*$~UNIX_GROUP_NAME=oinstall~' "$RSP_DEST"
sed -i 's~^[# ]*INVENTORY_LOCATION=.*$~INVENTORY_LOCATION={{ oracle_inventory }}~' "$RSP_DEST"
sed -i 's~^[# ]*ORACLE_HOME=.*$~ORACLE_HOME={{ oracle_home }}~' "$RSP_DEST"
sed -i 's~^[# ]*ORACLE_BASE=.*$~ORACLE_BASE={{ oracle_base }}~' "$RSP_DEST"

# 3. Comprehensive OS Group Mapping (Handles variants with/without "OS" prefixes)
# Targets: oracle.install.db.DBA_GROUP, oracle.install.db.OSDBA_GROUP, and OSDBA
sed -i 's~^[# ]*\(oracle.install.db.\(OS\)\?DBA_GROUP\|OSDBA\)=.*$~\1=dba~' "$RSP_DEST"
sed -i 's~^[# ]*\(oracle.install.db.\(OS\)\?OPER_GROUP\|OSOPER\)=.*$~\1=dba~' "$RSP_DEST"
sed -i 's~^[# ]*\(oracle.install.db.\(OS\)\?BACKUPDBA_GROUP\|OSBACKUPDBA\)=.*$~\1=dba~' "$RSP_DEST"
sed -i 's~^[# ]*\(oracle.install.db.\(OS\)\?DGDBA_GROUP\|OSDGDBA\)=.*$~\1=dba~' "$RSP_DEST"
sed -i 's~^[# ]*\(oracle.install.db.\(OS\)\?KMDBA_GROUP\|OSKMDBA\)=.*$~\1=dba~' "$RSP_DEST"
sed -i 's~^[# ]*\(oracle.install.db.\(OS\)\?RACDBA_GROUP\|OSRACDBA\)=.*$~\1=dba~' "$RSP_DEST"

# 4. Security and Support Updates
sed -i 's~^[# ]*SECURITY_UPDATES_VIA_MYORACLESUPPORT=.*$~SECURITY_UPDATES_VIA_MYORACLESUPPORT=false~' "$RSP_DEST"
sed -i 's~^[# ]*DECLINE_SECURITY_UPDATES=.*$~DECLINE_SECURITY_UPDATES=TRUE~' "$RSP_DEST"
